#!/usr/bin/env bash
set -euo pipefail

sock="${READ_SELECTION_TTS_SOCKET:-/tmp/read-selection-tts-mpv.sock}"
log="${READ_SELECTION_TTS_LOG:-/tmp/read-selection-tts.log}"

{
  date
  echo "continue requested"
} >>"$log"

if [ -S "$sock" ]; then
  printf '{"command":["set_property","pause",false]}\n' | nc -U "$sock" >>"$log" 2>&1 || true
fi
