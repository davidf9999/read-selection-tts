#!/usr/bin/env bash
set -euo pipefail

lib_file="${READ_SELECTION_TTS_LIB:-$HOME/.local/lib/read-selection-tts/common.sh}"
if [ ! -f "$lib_file" ] && [ -f "$(dirname "${BASH_SOURCE[0]}")/../lib/common.sh" ]; then
  lib_file="$(dirname "${BASH_SOURCE[0]}")/../lib/common.sh"
fi
# shellcheck source=lib/common.sh
. "$lib_file"

load_config
runtime_base="$(default_runtime_base)"
sock="${READ_SELECTION_TTS_SOCKET:-$runtime_base/mpv.sock}"
log="${READ_SELECTION_TTS_LOG:-$runtime_base/read-selection-tts.log}"

need python3
prepare_runtime
trim_log

{
  date
  echo "continue requested"
} >>"$log"

if [ -S "$sock" ]; then
  if ! python3 -c 'import socket, sys; s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM); s.connect(sys.argv[1]); s.sendall(sys.stdin.read().encode())' "$sock" <<<'{"command":["set_property","pause",false]}' >>"$log" 2>&1; then
    echo "continue command failed" >>"$log"
    exit 1
  fi
else
  echo "no active mpv socket" >>"$log"
fi
