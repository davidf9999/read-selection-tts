#!/usr/bin/env bash
set -euo pipefail

config="${READ_SELECTION_TTS_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/read-selection-tts/config}"
if [ -r "$config" ]; then
  # shellcheck disable=SC1090
  . "$config"
fi

runtime_base="${READ_SELECTION_TTS_RUNTIME_DIR:-${XDG_RUNTIME_DIR:-/tmp}/read-selection-tts}"
sock="${READ_SELECTION_TTS_SOCKET:-$runtime_base/mpv.sock}"
log="${READ_SELECTION_TTS_LOG:-$runtime_base/read-selection-tts.log}"

mkdir -p "$runtime_base"
chmod 700 "$runtime_base"

{
  date
  echo "continue requested"
} >>"$log"

if [ -S "$sock" ]; then
  printf '{"command":["set_property","pause",false]}\n' | nc -U "$sock" >>"$log" 2>&1 || true
fi
