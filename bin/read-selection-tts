#!/usr/bin/env bash
set -euo pipefail

export PATH="${PATH:-}:${HOME}/.local/bin:/usr/local/bin:/usr/bin:/bin"

lib_file="${READ_SELECTION_TTS_LIB:-$HOME/.local/lib/read-selection-tts/common.sh}"
if [ ! -f "$lib_file" ] && [ -f "$(dirname "${BASH_SOURCE[0]}")/../lib/common.sh" ]; then
  lib_file="$(dirname "${BASH_SOURCE[0]}")/../lib/common.sh"
fi
# shellcheck source=lib/common.sh
. "$lib_file"

load_config
voice="${READ_SELECTION_TTS_VOICE:-en-US-AriaNeural}"
runtime_base="$(default_runtime_base)"
media="${READ_SELECTION_TTS_MEDIA:-$runtime_base/read-selection.mp3}"
sock="${READ_SELECTION_TTS_SOCKET:-$runtime_base/mpv.sock}"
pidfile="${READ_SELECTION_TTS_PIDFILE:-$runtime_base/mpv.pid}"
log="${READ_SELECTION_TTS_LOG:-$runtime_base/read-selection-tts.log}"
lockfile="$runtime_base/lock"

selection_mode="primary"
while [ "$#" -gt 0 ]; do
  case "$1" in
    --stdin) selection_mode="stdin" ;;
    -h|--help)
      cat <<'USAGE'
Usage: read-selection-tts [--stdin]

Read selected Wayland primary-selection text aloud by default.
Use --stdin to read text from standard input instead, which is useful for
scripts and agent workflows.
USAGE
      exit 0
      ;;
    *) echo "read-selection-tts: unknown argument: $1" >&2; exit 2 ;;
  esac
  shift
done

selection_file="$runtime_base/read-selection.$$.txt"
media_tmp="$runtime_base/read-selection.$$.mp3"
edge_log="$runtime_base/edge-tts.$$.log"

# shellcheck disable=SC2317
cleanup_temp() {
  rm -f "$selection_file" "$media_tmp" "$edge_log"
}
trap cleanup_temp EXIT INT TERM

if [ "$selection_mode" = "primary" ]; then
  need wl-paste
fi
need edge-tts
need mpv
prepare_runtime
trim_log

stop_existing() {
  if [ -s "$pidfile" ]; then
    old_pid="$(cat "$pidfile" 2>/dev/null || true)"
    stop_pid "$old_pid"
  fi
  rm -f "$pidfile" "$sock"
}

{
  date
  echo "read requested voice=${voice}"
} >>"$log"

case "$selection_mode" in
  primary)
    if ! wl-paste --primary >"$selection_file" 2>>"$log"; then
      echo "wl-paste failed" >>"$log"
    fi
    ;;
  stdin)
    cat >"$selection_file"
    ;;
esac
if [ ! -s "$selection_file" ]; then
  if [ "$selection_mode" = "primary" ]; then
    echo "no primary selection" >>"$log"
  else
    echo "no stdin text" >>"$log"
  fi
  exit 0
fi

chars="$(wc -m <"$selection_file" 2>/dev/null | tr -d '[:space:]' || echo 0)"
echo "chars=${chars}" >>"$log"
rm -f "$media_tmp"
if ! edge-tts --voice "$voice" --file "$selection_file" --write-media "$media_tmp" >"$edge_log" 2>&1; then
  echo "edge-tts failed; leaving existing playback unchanged" >>"$log"
  exit 1
fi
rm -f "$edge_log"

(
  flock 9
  stop_existing
  mv -f "$media_tmp" "$media"
  mpv --no-video --really-quiet --input-ipc-server="$sock" "$media" 9>&- >>"$log" 2>&1 &
  mpv_pid=$!
  printf '%s\n' "$mpv_pid" >"$pidfile"
  # Release the lock so a second invocation can stop us and start fresh
  # while we are still waiting for playback to finish.
  flock -u 9
  set +e
  wait "$mpv_pid"
  wait_status=$?
  set -e
  if [ -s "$pidfile" ] && [ "$(cat "$pidfile" 2>/dev/null || true)" = "$mpv_pid" ]; then
    rm -f "$pidfile" "$sock"
  fi
  exit "$wait_status"
) 9>"$lockfile"
